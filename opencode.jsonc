{
  "$schema": "https://opencode.ai/config.json",
  "commands": {
    "feature-workflow": {
      "description": "Run spec-based feature workflow: /context -> /spec -> /validate -> /architect -> /validate -> /implement -> /test -> /reflect -> /review -> /commit -> /wrapup"
    },
    "proceed": {
      "description": "Run end-to-end ADLC-compatible pipeline with validation gates"
    },
    "status": {
      "description": "Show workflow status and recommended next command"
    },
    "bugfix": {
      "description": "Run streamlined defect flow: report -> analyze -> fix -> verify"
    },
    "wrapup": {
      "description": "Finalize feature artifacts and capture durable knowledge"
    }
  },
  "mcp": {
    "ryan-mcp": {
      "type": "remote",
      "url": "http://localhost:8787/mcp",
      "enabled": true,
      "oauth": false,
      "timeout": 120000,
    },
    "aspire": {
      "type": "local",
      "command": ["aspire", "agent", "mcp"],
      "enabled": true,
    },
  },
}
