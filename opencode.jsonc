{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "ryan-mcp": {
      "type": "local",
      "command": ["dotnet", "run", "--project", "mcp-server/src/Ryan.MCP.AppHost/Ryan.MCP.AppHost.csproj"],
      "enabled": true
    },
    "aspire": {
      "type": "local",
      "command": ["aspire", "agent", "mcp"],
      "enabled": true
    }
  }
}
