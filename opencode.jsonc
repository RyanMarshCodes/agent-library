{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "ryan-mcp": {
      "type": "remote",
      "url": "http://localhost:8787/mcp",
      "enabled": true,
      "oauth": false,
      "timeout": 120000,
    },
    "aspire": {
      "type": "local",
      "command": ["aspire", "agent", "mcp"],
      "enabled": true,
    },
  },
}
