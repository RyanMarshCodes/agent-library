{
  "inputs": [],
  "servers": {
  "chrome-devtools": {
    "command": "npx",
    "args": [
      "-y",
      "chrome-devtools-mcp@latest"
    ]
  },
  "ryan-mcp": {
    "command": "curl",
    "args": [
      "http://localhost:8787/mcp"
    ]
  },
  "aspire": {
    "command": "aspire",
    "args": [
      "agent",
      "mcp"
    ]
  },
  "playwright": {
    "command": "npx",
    "args": [
      "@playwright/mcp@latest"
    ]
  },
  "filesystem": {
    "command": "npx",
    "args": [
      "-y",
      "@modelcontextprotocol/server-filesystem",
      "."
    ]
  }
}
}