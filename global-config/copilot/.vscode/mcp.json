{
  "inputs": [],
  "servers": {
  "ryan-mcp": {
    "args": [
      "http://localhost:8787/mcp"
    ],
    "command": "curl"
  },
  "playwright": {
    "args": [
      "@playwright/mcp@latest"
    ],
    "command": "npx"
  },
  "filesystem": {
    "args": [
      "-y",
      "@modelcontextprotocol/server-filesystem",
      "."
    ],
    "command": "npx"
  },
  "aspire": {
    "args": [
      "agent",
      "mcp"
    ],
    "command": "aspire"
  },
  "chrome-devtools": {
    "args": [
      "-y",
      "chrome-devtools-mcp@latest"
    ],
    "command": "npx"
  }
}
}