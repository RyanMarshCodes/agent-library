{
  "mcpServers": {
    "ryan-mcp": {
      "url": "http://localhost:8787/mcp",
      "type": "http"
    },
    "playwright": {
      "args": [
        "@playwright/mcp@latest"
      ],
      "command": "npx",
      "type": "local",
      "tools": [
        "*"
      ]
    },
    "filesystem": {
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "."
      ],
      "command": "npx",
      "type": "local",
      "tools": [
        "*"
      ]
    },
    "aspire": {
      "args": [
        "agent",
        "mcp"
      ],
      "command": "aspire",
      "type": "local",
      "tools": [
        "*"
      ]
    },
    "chrome-devtools": {
      "args": [
        "-y",
        "chrome-devtools-mcp@latest"
      ],
      "command": "npx",
      "type": "local",
      "tools": [
        "*"
      ]
    }
  }
}