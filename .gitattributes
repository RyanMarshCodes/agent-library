# Auto-detect text files and normalize to LF in the repo
* text=auto eol=lf

# Force LF for shell scripts
*.sh text eol=lf

# Force CRLF for PowerShell (Windows convention)
*.ps1 text eol=crlf
*.psm1 text eol=crlf
*.psd1 text eol=crlf

# Force LF for common text files
*.md text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.cs text eol=lf
*.csproj text eol=lf
*.sln text eol=lf
*.props text eol=lf
*.targets text eol=lf
*.sql text eol=lf

# Binary files — do not touch
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary
*.gz binary
*.tar binary
